{
  "fileSuggestion": {
    "type": "command",
    "command": "ccfilesuggestion"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read(~/src/**)",
      "Edit(~/src/**)",
      "Write(~/src/**)",
      "Bash(bundle exec rails db\\:migrate:*)",
      "Bash(bundle exec rspec:*)",
      "Bash(bundle exec rubocop:*)",
      "Bash(bundle install:*)",
      "Bash(cargo:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(cp:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(git:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(notify-send:*)",
      "Bash(rg:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(touch:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "mcp__copy-tuner__get_locales",
      "Bash(rails runner:*)",
      "Bash(bundle exec rails runner:*)",
      "Bash(ruby -e:*)",
      "Bash(DEBUG_PARSER=1 bundle exec rspec:*)",
      "mcp__copy-tuner__search_translations",
      "mcp__copy-tuner__search_key",
      "Bash(bin/rails runner:*)"
    ],
    "deny": [
      "mcp__supabase__execute_sql",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Bash(sudo:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git config:*)",
      "Bash(git remote:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(systemctl:*)",
      "Read(.env*)",
      "Read(**/*secret*)",
      "Read(**/*credentials*)",
      "Read(**/config/master.key)"
    ],
    "ask": [
      "Bash(gh repo delete:*)",
      "Bash(gh repo edit:*)",
      "Bash(gh repo rename:*)",
      "Bash(gh repo archive:*)",
      "Bash(gh repo unarchive:*)",
      "Bash(gh repo create:*)",
      "Bash(gh repo deploy-key add:*)",
      "Bash(gh release delete:*)",
      "Bash(gh release create:*)",
      "Bash(gh release edit:*)",
      "Bash(gh release upload:*)",
      "Bash(gh gist delete:*)",
      "Bash(gh gist create:*)",
      "Bash(gh cache delete:*)",
      "Bash(gh run delete:*)",
      "Bash(gh run rerun:*)",
      "Bash(gh workflow run:*)",
      "Bash(gh workflow enable:*)",
      "Bash(gh workflow disable:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh label delete:*)",
      "Bash(gh ssh-key add:*)",
      "Bash(gh ssh-key delete:*)",
      "Bash(gh gpg-key add:*)",
      "Bash(gh gpg-key delete:*)",
      "Bash(gh secret set:*)",
      "Bash(gh secret delete:*)",
      "Bash(gh variable set:*)",
      "Bash(gh variable delete:*)",
      "Bash(gh auth login:*)",
      "Bash(gh auth logout:*)",
      "Bash(gh auth refresh:*)",
      "Bash(gh auth token:*)",
      "Bash(gh api:*)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/home/maedana/todotxt"
    ]
  },
  "model": "claude-opus-4-6[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ccnotify"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ccnotify"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "crmux notify session-start"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccstatus",
    "padding": 0
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "install-skills-for-remote@sonicgarden-plugins": true
  },
  "extraKnownMarketplaces": {
    "sonicgarden-plugins": {
      "source": {
        "source": "github",
        "repo": "SonicGarden/claude-plugins"
      }
    }
  },
  "language": "japanese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "tui": "default",
  "autoScrollEnabled": false,
  "skipAutoPermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754374065544
  }
}
